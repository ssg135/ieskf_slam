<launch>
    <arg name="lidar_topic" default="/lidar_points" />
    <arg name="imu_topic" default="/A000/imu" />
    <rosparam command="load" file="$(find ieskf_slam)/config/generic.yaml" />
    <param name="wrapper/lidar_topic" value="$(arg lidar_topic)" />
    <param name="wrapper/imu_topic" value="$(arg imu_topic)" />
    <node pkg="ieskf_slam" type="ieskf_slam_node" name="ieskf_slam_node" output="screen" />
	<node pkg="rviz" type="rviz" name="rviz" args="-d $(find ieskf_slam)/rviz/show.rviz" />
</launch>
